<div class="card bg-base-100 shadow-sm">
  <div class="card-body p-4">
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-xs text-base-content/60">月合計</p>
        <p class="text-2xl font-bold">¥<%= number_with_delimiter(summary[:total_amount]) %></p>
      </div>
      <div>
        <p class="text-xs text-base-content/60">1日平均</p>
        <p class="text-2xl font-bold">¥<%= number_with_delimiter(summary[:daily_average]) %></p>
      </div>
      <div>
        <p class="text-xs text-base-content/60">最高日</p>
        <% if summary[:best_day] %>
          <p class="text-2xl font-bold">¥<%= number_with_delimiter(summary[:best_day][:amount]) %></p>
          <p class="text-[10px] text-base-content/50"><%= summary[:best_day][:date].strftime("%-m/%-d") %></p>
        <% else %>
          <p class="text-2xl font-bold">-</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
