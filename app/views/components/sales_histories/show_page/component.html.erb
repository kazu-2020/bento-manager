<% content_for(:title, "販売履歴 #{I18n.l(date, format: :long)}") %>

<div class="space-y-6">
  <%# パンくず %>
  <div class="text-sm breadcrumbs">
    <ul>
      <li><%= link_to "販売履歴", back_path %></li>
      <li><%= date.strftime("%Y年%m月") %></li>
      <li><%= I18n.l(date, format: :long) %></li>
    </ul>
  </div>

  <%# 日次サマリー %>
  <%= component "sales_histories/daily_summary",
        total_amount: total_amount,
        total_transactions: total_transactions,
        location: location %>

  <%# 取引一覧 %>
  <%= component "sales_histories/transaction_table",
        sales: sales %>

  <%# 戻るリンク %>
  <div class="text-center">
    <%= link_to "← カレンダーに戻る", back_path, class: "link link-primary text-sm" %>
  </div>
</div>
