<%= helpers.turbo_frame_tag "sales_analysis_cross_table" do %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-base">商品 × 顧客タイプ クロス集計</h3>
      <% if data.empty? %>
        <p class="text-sm text-base-content/50 py-4">データがありません</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>商品</th>
                <th class="text-right">合計</th>
                <th class="text-right">構成比</th>
                <th class="text-right text-primary">関係者</th>
                <th class="text-right text-info">一般</th>
                <th class="text-right">職員比率</th>
              </tr>
            </thead>
            <tbody>
              <% data.each do |row| %>
                <tr>
                  <td><%= row[:catalog_name] %></td>
                  <td class="text-right font-bold"><%= row[:total_quantity] %></td>
                  <td class="text-right"><%= composition_ratio(row) %>%</td>
                  <td class="text-right text-primary"><%= row[:staff_quantity] %></td>
                  <td class="text-right text-info"><%= row[:citizen_quantity] %></td>
                  <td class="text-right"><%= staff_ratio(row) %>%</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
