<%= helpers.turbo_frame_tag "sales_analysis_cross_table" do %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-base">弁当 × 顧客タイプ クロス集計</h3>
      <% if data.empty? %>
        <p class="text-sm text-base-content/50 py-4">データがありません</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>商品</th>
                <th class="text-right">合計</th>
                <th>構成比 <span class="text-xs font-normal text-staff">■</span><span class="text-xs font-normal text-base-content/50">関係者</span> <span class="text-xs font-normal text-citizen">■</span><span class="text-xs font-normal text-base-content/50">一般</span></th>
                <th class="text-right">関係者比率</th>
              </tr>
            </thead>
            <tbody>
              <% data.each do |row| %>
                <tr>
                  <td><%= row[:catalog_name] %></td>
                  <td class="text-right font-bold"><%= row[:total_quantity] %></td>
                  <td>
                    <div class="flex items-center gap-2">
                      <div class="flex h-5 rounded-full overflow-hidden flex-1" style="width: <%= bar_total_width(row) %>">
                        <div class="bg-staff rounded-l-full" style="width: <%= staff_bar_ratio(row) %>"></div>
                        <div class="bg-citizen rounded-r-full flex-1"></div>
                      </div>
                      <span class="text-xs text-staff whitespace-nowrap"><%= row[:staff_quantity] %></span>
                      <span class="text-xs text-base-content/30">/</span>
                      <span class="text-xs text-citizen whitespace-nowrap"><%= row[:citizen_quantity] %></span>
                    </div>
                  </td>
                  <td class="text-right"><%= staff_ratio(row) %>%</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
